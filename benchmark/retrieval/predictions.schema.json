{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UniRegBench Retrieval Prediction",
  "type": "object",
  "required": ["question_id", "ranked_citations"],
  "additionalProperties": false,
  "properties": {
    "question_id": { "type": "string", "minLength": 1 },
    "ranked_citations": {
      "type": "array",
      "items": { "$ref": "../questions/questions.schema.json#/$defs/gold_citation" }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
